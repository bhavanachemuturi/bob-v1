# Use public npm registry instead of artifactory
registry=https://registry.npmjs.org/

# Disable strict SSL if needed (use with caution)
# strict-ssl=false

# Set longer timeout for slow connections
fetch-timeout=60000
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Disable package-lock for faster installs (optional)
# package-lock=false

# Use legacy peer deps to avoid conflicts
legacy-peer-deps=true

# Force resolution of dependencies
force=true

# Made with Bob
